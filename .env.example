# ============================================================
# API Test Agent — 环境变量配置模板
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# ============================================================

# === DeepSeek LLM（必填） ===
# 注册地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# === Qdrant 向量数据库 ===
# Docker 部署时 host 自动设为 qdrant（容器名）
QDRANT_HOST=localhost
QDRANT_PORT=16333
QDRANT_COLLECTION=api_test_specs

# === SQLite 持久化 ===
SQLITE_PATH=./data/api_test.db

# === LangFuse 可观测性（可选，本地自托管） ===
# 不填则禁用 LangFuse 追踪
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# === 服务端口 ===
API_HOST=0.0.0.0
API_PORT=8002

# === 日志级别 ===
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=./data/api_test.log

# === Agent 行为配置 ===
MAX_TEST_ITERATIONS=80
REQUEST_TIMEOUT=30
SANDBOX_ENABLED=true
